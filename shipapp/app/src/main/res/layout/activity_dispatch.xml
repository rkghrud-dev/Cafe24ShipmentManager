<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ship_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDispatch"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/ship_primary"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
        android:title="출고 / 송장 처리"
        android:titleTextColor="@color/ship_on_primary"
        app:navigationIcon="@drawable/ic_menu_24"
        app:titleCentered="true"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- 조회 조건 패널 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ship_surface"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 마켓 선택 스피너 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="마켓"
                android:textColor="@color/ship_text_secondary"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinnerMarket"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_inline_panel"
                android:padding="4dp" />
        </LinearLayout>

        <!-- 조회기간 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="기간"
                android:textColor="@color/ship_text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartDate"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="~"
                android:textColor="@color/ship_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEndDate"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 조회 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuery"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:text="조회"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 진행 표시 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:visibility="gone"
        style="?android:attr/progressBarStyleHorizontal" />

    <!-- 액션 바 (결과 있을 때만 표시) -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ship_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="전체선택"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeselectAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="전체해제"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDispatch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="2"
            android:text="선택 출고처리 (0건)"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 상태 메시지 -->
    <TextView
        android:id="@+id/tvStatusMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="20dp"
        android:text="마켓과 기간을 선택 후 조회하세요."
        android:textColor="@color/ship_text_secondary"
        android:textSize="13sp"
        android:visibility="visible" />

    <!-- 주문 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"
        android:clipToPadding="false" />

</LinearLayout>
