<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ship_background"
    android:orientation="vertical">

    <!-- iOS 스타일 툴바: 흰 배경 + 다크 텍스트 + 하단 구분선 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDispatch"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@color/ship_surface"
        android:elevation="0dp"
        android:title="출고처리"
        app:navigationIcon="@drawable/ic_back_24"
        app:titleCentered="true"
        app:titleTextAppearance="@style/TextAppearance.DispatchTitle" />

    <!-- 툴바 하단 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/ship_outline" />

    <!-- 조회 조건 패널 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ship_surface"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- 마켓 선택 스피너 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="마켓"
                android:textColor="@color/ship_text_secondary"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinnerMarket"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tracking_input"
                android:padding="4dp" />
        </LinearLayout>

        <!-- 조회기간 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="기간"
                android:textColor="@color/ship_text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartDate"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="–"
                android:textColor="@color/ship_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEndDate"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 조회 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuery"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:text="조회"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 패널 하단 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/ship_outline" />

    <!-- 진행 표시 -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- 액션 바 (결과 있을 때만 표시) -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ship_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="전체선택"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeselectAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="전체해제"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDispatch"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="2"
            android:text="선택 출고처리 (0건)"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 액션바 하단 구분선 -->
    <View
        android:id="@+id/dividerActions"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/ship_outline"
        android:visibility="gone" />

    <!-- 상태 메시지 -->
    <TextView
        android:id="@+id/tvStatusMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="마켓과 기간을 선택 후 조회하세요."
        android:textColor="@color/ship_text_secondary"
        android:textSize="13sp"
        android:visibility="visible" />

    <!-- 주문 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

</LinearLayout>
