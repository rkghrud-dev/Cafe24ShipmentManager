<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="6dp">

    <LinearLayout
        android:id="@+id/widgetMarket1Tile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/bg_inline_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="3dp">

        <TextView
            android:id="@+id/widgetMarket1Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="홈런"
            android:textColor="@color/ship_text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetMarket1Count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="--"
            android:textColor="@color/ship_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetMarket2Tile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_weight="1"
        android:background="@drawable/bg_inline_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="3dp">

        <TextView
            android:id="@+id/widgetMarket2Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="준비"
            android:textColor="@color/ship_text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetMarket2Count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="--"
            android:textColor="@color/ship_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetMarket3Tile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_weight="1"
        android:background="@drawable/bg_inline_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="3dp">

        <TextView
            android:id="@+id/widgetMarket3Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="쿠팡"
            android:textColor="@color/ship_text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetMarket3Count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="--"
            android:textColor="@color/ship_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetMarket4Tile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_weight="1"
        android:background="@drawable/bg_inline_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="3dp">

        <TextView
            android:id="@+id/widgetMarket4Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="전체"
            android:textColor="@color/ship_text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetMarket4Count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="--"
            android:textColor="@color/ship_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widgetRefreshButton"
        android:layout_width="36dp"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:background="@drawable/bg_inline_panel"
        android:contentDescription="주문 새로고침"
        android:gravity="center"
        android:text="↻"
        android:textColor="@color/ship_primary"
        android:textSize="20sp"
        android:textStyle="bold" />
</LinearLayout>
